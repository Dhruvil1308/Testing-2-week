# === GuniVox Environment Variables ===
# Copy this file to .env.local and fill in your values.
# On Render, set these as Environment Variables in the dashboard.

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_CALLER_ID=+1xxxxxxxxxx

# Google Gemini (for frontend voice agent)
GEMINI_API_KEY=your-gemini-api-key

# Public URL for Twilio webhooks (auto-set on Render via RENDER_EXTERNAL_URL)
# For local dev, leave blank and use ngrok instead.
# BASE_URL=https://your-app.onrender.com
